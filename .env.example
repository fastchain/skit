# Copy to .env and adjust
XMPP_DOMAIN=db.dfsf.org
PUBLIC_IPV4=203.0.113.10

# Let's Encrypt — email address used for certificate notifications.
# Port 80 must be reachable from the internet for the HTTP-01 ACME challenge.
ACME_EMAIL=admin@db.dfsf.org

# PostgreSQL (used by ejabberd)
POSTGRES_DB=ejabberd
POSTGRES_USER=ejabberd
POSTGRES_PASSWORD=ejabberd
